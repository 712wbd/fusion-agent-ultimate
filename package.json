{
  "name": "fusion-agent-ultimate",
  "version": "1.0.0",
  "description": "世界頂級融合智能體 - 整合多模態 AI、自適應學習、全棧開發、安全掃描、性能優化於一體的革命性插件",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "claude-plugin",
    "ai-agent",
    "code-generation",
    "performance-optimization",
    "security-scanner",
    "adaptive-learning",
    "full-stack",
    "fusion-ai"
  ],
  "author": {
    "name": "712wbd",
    "email": "712wbd@github.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/712wbd/fusion-agent-ultimate.git"
  },
  "homepage": "https://github.com/712wbd/fusion-agent-ultimate#readme",
  "bugs": {
    "url": "https://github.com/712wbd/fusion-agent-ultimate/issues"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "plugin:validate": "node scripts/validate-plugin.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@langchain/core": "^0.1.60",
    "@langchain/anthropic": "^0.1.20",
    "@langchain/community": "^0.0.50",
    "langchain": "^0.1.35",
    "zod": "^3.23.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^9.2.15",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "globby": "^14.0.1",
    "winston": "^3.13.0",
    "dotenv": "^16.4.5",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "tsx": "^4.7.2",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0",
    "@vitest/ui": "^1.5.0",
    "@vitest/coverage-v8": "^1.5.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
